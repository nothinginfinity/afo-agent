{
  "name": "@afo/agent",
  "version": "0.1.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:example": "tsx examples/release-blogger.ts",
    "dev:lead": "tsx examples/lead-agent.ts",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "manifests:validate": "node scripts/sync-d1-manifests.mjs --dry-run",
    "manifests:sync": "node scripts/sync-d1-manifests.mjs --require-secrets"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250619.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  }
}
